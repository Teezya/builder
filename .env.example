# AI Startup Builder - Переменные окружения

# Server
NODE_ENV=development
PORT=5000

# JWT
JWT_SECRET=your_secure_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# xAI Grok API
XAI_API_KEY=your_xai_api_key_here
XAI_API_BASE=https://api.x.ai/v1
XAI_MODEL=grok-4.3
XAI_GROK_MODELS=grok-4.3,grok-4.20,grok-4,grok-4.3-mini,grok-4-mini,grok-4.1
XAI_MODELS_TIMEOUT_MS=8000
XAI_REQUEST_TIMEOUT_MS=45000

# Database
# По умолчанию используется JSON файл (db.json), для production используйте MongoDB:
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# PostgreSQL mirror (zero-downtime migration)
PG_MIRROR_ENABLED=false
PG_PRIMARY_ENABLED=false
PG_WRITE_JSON_FALLBACK=true
PG_INITIAL_SYNC_ON_BOOT=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_startup_builder
PG_SSL_MODE=disable
PG_POOL_MAX=10
PG_MIRROR_DEBOUNCE_MS=1200
PG_ADMIN_TOKEN=change_me_for_admin_sync
PG_CONSISTENCY_CHECK_ENABLED=true
PG_CONSISTENCY_CHECK_INTERVAL_MS=60000
PG_CONSISTENCY_ALERT_WEBHOOK_URL=
PG_CONSISTENCY_ALERT_CHANNEL=generic
PG_CONSISTENCY_ALERT_TELEGRAM_BOT_TOKEN=
PG_CONSISTENCY_ALERT_TELEGRAM_CHAT_ID=
PG_CONSISTENCY_ALERT_COOLDOWN_MS=300000
PG_CONSISTENCY_ALERT_TIMEOUT_MS=8000

# CORS
CORS_ORIGIN=http://localhost:3000

# Компрессия
COMPRESSION_LEVEL=6
COMPRESSION_MIN_SIZE=1024

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cache
CACHE_TTL=60000
CACHE_MAX_SIZE=100
